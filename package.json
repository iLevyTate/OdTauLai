{
  "name": "odtaulai",
  "private": true,
  "description": "Static PWA — npm scripts are for CI and local checks only (no install step).",
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "check:version": "node scripts/check-version-sync.mjs",
    "check:assets": "node scripts/check-assets.mjs",
    "check": "npm run check:version && npm run check:assets",
    "smoke": "node scripts/smoke-check.mjs",
    "smoke:deep": "node scripts/smoke-deep.mjs",
    "smoke:exhaustive": "node scripts/smoke-exhaustive.mjs",
    "verify:handlers": "node scripts/verify-handlers.mjs",
    "verify:inline": "node scripts/find-inline.mjs",
    "bump:version": "node scripts/bump-version.mjs",
    "build:icons": "node scripts/build-icons.mjs"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
